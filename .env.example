# =====================================================================
# HH Perfomance — instancia Neura ERP monocliente
# Copiar a `.env.local` y completar. NUNCA versionar el archivo con valores.
# =====================================================================

# --- Supabase (self-hosted) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=

# --- Identidad de la instancia ---
# El schema debe existir en PostgreSQL y estar expuesto en PostgREST.
# No apuntar nunca a `public` ni al schema de otro cliente.
APP_DB_SCHEMA=hhperfomance
NEXT_PUBLIC_APP_DB_SCHEMA=hhperfomance
NEURA_CLIENT_SCHEMA=hhperfomance
NEURA_INSTANCE_MODE=single_client
NEURA_CLIENT_NAME=HH Perfomance
NEXT_PUBLIC_NEURA_CLIENT_NAME=HH Perfomance
